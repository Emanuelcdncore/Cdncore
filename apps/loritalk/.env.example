# Meta (Facebook) Pixel ID. Pixel only loads when the visitor opts in to
# marketing cookies via the consent banner. Unset to disable entirely.
NEXT_PUBLIC_META_PIXEL_ID=2426542774480370

# Backend URL the landing posts captured Pixel attribution to. The
# /attribution endpoint records fbp / fbc / fbclid + event_id so the
# Stripe webhook handler can later replay them as a CAPI Purchase event.
# Local dev: http://localhost:3000
# Production: https://app.lori-talk.eu (or the app subdomain in front of
# the backend).
NEXT_PUBLIC_BACKEND_URL=https://app.lori-talk.eu
